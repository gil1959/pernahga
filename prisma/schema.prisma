// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  phone         String?
  company       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  consultations Consultation[]
  savedItems    SavedItem[]
  testimonials  Testimonial[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Package {
  id          String   @id @default(cuid())
  title       String
  titleEn     String
  description String   @db.Text
  descriptionEn String @db.Text
  price       String
  priceNote   String?
  priceNoteEn String?
  features    String   @db.Text // JSON array
  featuresEn  String   @db.Text // JSON array
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Showcase {
  id              String   @id @default(cuid())
  title           String
  titleEn         String
  slug            String   @unique
  description     String   @db.Text
  descriptionEn   String   @db.Text
  longDescription String   @db.Text
  longDescriptionEn String @db.Text
  thumbnail       String
  images          String   @db.Text // JSON array
  tags            String   @db.Text // JSON array
  techStack       String   @db.Text // JSON array
  demoUrl         String?
  caseStudy       String?  @db.Text
  caseStudyEn     String?  @db.Text
  isPublished     Boolean  @default(false)
  isFeatured      Boolean  @default(false)
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  savedItems SavedItem[]
}

model Education {
  id           String        @id @default(cuid())
  title        String
  titleEn      String
  description  String?       @db.Text
  descriptionEn String?      @db.Text
  type         EducationType @default(YOUTUBE)
  embedUrl     String
  thumbnailUrl String?
  category     String?
  categoryEn   String?
  isPublished  Boolean       @default(true)
  order        Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  company     String?
  role        String?
  avatar      String?
  content     String   @db.Text
  contentEn   String?  @db.Text
  rating      Int      @default(5)
  isPublished Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Consultation {
  id         String             @id @default(cuid())
  userId     String
  name       String
  email      String
  company    String?
  topic      String
  message    String             @db.Text
  status     ConsultationStatus @default(PENDING)
  adminNotes String?            @db.Text
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedItem {
  id         String   @id @default(cuid())
  userId     String
  showcaseId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  showcase Showcase @relation(fields: [showcaseId], references: [id], onDelete: Cascade)

  @@unique([userId, showcaseId])
}

model SiteSettings {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String   @db.Text
  updatedAt       DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum EducationType {
  YOUTUBE
  TIKTOK
}

enum ConsultationStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CANCELLED
}
